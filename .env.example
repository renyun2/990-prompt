# cp .env.example .env

# ── 数据库连接（web 服务使用）──────────────────────────
DB_HOST=db
DB_USER=member_user
DB_PASSWORD=member_pass123
DB_NAME=member_system
DB_PORT=3306

# ── MySQL 容器初始化（db 服务使用）────────────────────
MYSQL_ROOT_PASSWORD=root123456

# ── 应用配置 ───────────────────────────────────────────
APP_DEBUG=true
APP_NAME=会员注册管理系统
